# ── gridbot API ───────────────────────────────────────────────────────────
# Copy to `.env` (or `.env.local`) and adjust. `.env.local` wins over `.env`.

GRIDBOT_PORT=8787
GRIDBOT_DB_PATH=./data/gridbot.sqlite
# How often (ms) each bot re-quotes its grid.
GRIDBOT_RECONCILE_MS=1500
# Per-side fee rate assumed when rejecting grids whose spacing can't cover fees.
GRIDBOT_ASSUMED_FEE_RATE=0.0002
# Dashboard origin allowed by CORS.
GRIDBOT_CORS_ORIGIN=http://localhost:3000
GRIDBOT_LOG_LEVEL=info

# ── Live venue credentials (leave blank to run paper only) ──────────────────
# NEVER commit real keys. Prefer .env.local or a secret manager.
# Extended (Starknet) — needs all three: Stark private key + API key + vault id.
GRIDBOT_EXTENDED_PRIVATE_KEY=
GRIDBOT_EXTENDED_API_KEY=
GRIDBOT_EXTENDED_VAULT_ID=
# Extended order signing is UNVERIFIED. Placement is refused unless you set this
# to "true" — only after validating the signing against an Extended testnet fill.
GRIDBOT_EXTENDED_ALLOW_UNVERIFIED_SIGNING=false
# Decibel (Aptos) — API-wallet Ed25519 key + trading-account (subaccount) address.
# Signing goes through the official @decibeltrade/sdk. Live trading submits real
# on-chain Aptos transactions (gas + funds) and is off unless ALLOW_LIVE=true.
GRIDBOT_DECIBEL_PRIVATE_KEY=
GRIDBOT_DECIBEL_SUBACCOUNT_ADDRESS=
GRIDBOT_DECIBEL_NODE_API_KEY=
GRIDBOT_DECIBEL_ALLOW_LIVE=false
# RISEx (RISE Chain / EVM) — session/signer key + account address.
# Signing is done locally by the community risex-client SDK (EIP-712, key never
# leaves the process). Register the signer key in the RISEx web UI first.
# The SDK is "not production ready" + RISE is early-mainnet, so live is OFF by
# default. Validate on testnet before enabling.
GRIDBOT_RISEX_PRIVATE_KEY=
GRIDBOT_RISEX_ACCOUNT_ADDRESS=
GRIDBOT_RISEX_COLLATERAL_TOKEN=
GRIDBOT_RISEX_ALLOW_LIVE=false

# ── AI advisor (optional) ───────────────────────────────────────────────────
# Provider suggests grid params from recent price action. Leave blank to disable.
# anthropic | deepseek | gemini
GRIDBOT_AI_PROVIDER=
GRIDBOT_AI_API_KEY=
# Optional model override (defaults: claude-opus-4-8 / deepseek-chat / gemini-2.5-flash)
GRIDBOT_AI_MODEL=
# Scheduled AI capabilities (0 / -1 = off). Sentinel pushes a notification on
# anomaly; the daily report fires once when the local hour first matches.
GRIDBOT_AI_SENTINEL_MINUTES=0
GRIDBOT_AI_REPORT_HOUR=-1

# ── Notifications (optional) ────────────────────────────────────────────────
GRIDBOT_TELEGRAM_BOT_TOKEN=
GRIDBOT_TELEGRAM_CHAT_ID=
GRIDBOT_WEBHOOK_URL=

# ── Outbound proxy (optional) ───────────────────────────────────────────────
# Routes all exchange + AI HTTP through this proxy (http://user:pass@host:port).
GRIDBOT_PROXY_URL=

# ── Web dashboard ───────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8787
